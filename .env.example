# ─── CONSULTA FÁCIL API — Environment Variables ─────────────────────────────
# Copy to .env and fill in values. Never commit the actual .env file.
#
# DEV:  Required vars marked [DEV-REQUIRED]. Others have safe defaults in
#       application.properties and can be left blank locally.
# PROD: ALL vars marked [PROD-REQUIRED] must be set. Application aborts on
#       startup if any are missing (see ProdEnvironmentValidator).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# [PROD-REQUIRED] Full JDBC URL to your PostgreSQL instance
DB_URL=jdbc:postgresql://localhost:5432/consulta_facil_db

# [PROD-REQUIRED] Database credentials
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ─── Security ────────────────────────────────────────────────────────────────
# [PROD-REQUIRED] JWT signing secret — min 32 chars, cryptographically random
# Generate: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-secret-with-at-least-32-characters

# ─── Application URL ─────────────────────────────────────────────────────────
# [PROD-REQUIRED] Public URL of the app (used in payment redirect URLs)
APP_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# [PROD-REQUIRED] Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── AWS ─────────────────────────────────────────────────────────────────────
# [PROD-REQUIRED] AWS credentials for S3 uploads
# In production on ECS, prefer IAM task role (leave blank to use instance role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# [PROD-REQUIRED] S3 bucket name for avatar/file uploads
AWS_S3_BUCKET=consulta-facil-images

# ─── MercadoPago ─────────────────────────────────────────────────────────────
# [PROD-REQUIRED] Payment processor token
# Test token: TEST-... | Prod token: APP_USR-...
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token-here

# ─── Grafana Cloud Observability ─────────────────────────────────────────────
# [PROD-REQUIRED] OTLP endpoint — Grafana Cloud > My Account > OpenTelemetry
# Format: https://otlp-gateway-<region>.grafana.net/otlp
GRAFANA_OTLP_ENDPOINT=

# [PROD-REQUIRED] Base64-encoded "instanceId:apiKey"
# Generate: echo -n "<instanceId>:<apiKey>" | base64
GRAFANA_OTLP_TOKEN=

# ─── Integrations (Optional) ─────────────────────────────────────────────────
# Twilio WhatsApp notifications (leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Claude AI (voice booking feature — leave blank to disable)
ANTHROPIC_API_KEY=

# ─── Spring Profile ───────────────────────────────────────────────────────────
# Use 'prod' in production, leave unset locally (defaults to dev behavior)
SPRING_PROFILES_ACTIVE=
