# Copie este arquivo para terraform.tfvars e preencha os valores reais.
# NUNCA commite terraform.tfvars (está no .gitignore).

aws_region   = "us-east-1"
project_name = "consulta-facil"
environment  = "prod"

# Banco de dados
db_password       = "TROQUE_POR_SENHA_SEGURA"
db_instance_class = "db.t3.micro"

# Segurança
jwt_secret = "TROQUE_POR_SEGREDO_JWT_COM_MINIMO_256_BITS"

# URLs do frontend (sem barra no final)
cors_allowed_origins = "https://app.seudominio.com"
app_url              = "https://app.seudominio.com"

# MercadoPago (opcional)
mercadopago_access_token = "APP_USR-..."

# S3
s3_bucket_name = "consulta-facil-images-prod"
